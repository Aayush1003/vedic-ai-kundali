# Backend Environment Variables
# Copy this file to .env.local and fill in the values

# Server Configuration
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vedic_db

# Redis (Caching & Job Queue)
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key
JWT_REFRESH_EXPIRE=30d

# OpenAI API
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=1000

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret

# Email Configuration
EMAIL_FROM=noreply@vedic-ai.com
SENDGRID_API_KEY=your-sendgrid-key-here
# OR use nodemailer with Gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Geocoding API (for location coordinates)
GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# Application URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# Cors Origin
CORS_ORIGIN=http://localhost:3000

# Swiss Ephemeris Data Path
EPHEMERIS_DATA_PATH=./data/ephemeris

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Sentry (Error Tracking - Optional)
SENTRY_DSN=

# Feature Flags
ENABLE_PUJA_RECOMMENDATIONS=true
ENABLE_MIHURAT_FINDER=false
ENABLE_DETAILED_DASHA=false
